# Copy to .env.local and fill in. Everything runs WITHOUT a key in mock mode.

# --- LLM provider (OpenAI-compatible) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# --- Demo safety net ---
# MOCK_LLM=1 returns deterministic, on-brand responses (no network, no key).
# The research synthesis, the forge tool, and the eval suite all run offline.
MOCK_LLM=1

# --- Live wall storage (Vercel KV) ---
# When these are set, the live wall is shared across all serverless instances
# (so a whole room writes to one wall). Leave them empty for local/offline dev —
# the app automatically falls back to an in-memory wall.
# Get these by adding a KV store in the Vercel dashboard, or `vercel env pull`.
KV_REST_API_URL=
KV_REST_API_TOKEN=
